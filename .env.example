# --- Required ---
# توکن ربات باله (از @BotFather بگیرید)
BALE_BOT_TOKEN=your_bale_bot_token_here

# --- Optional ---
# کلید API رسلر (برای خرید دامنه و هاست)
RESELLER_API_KEY=your_reseller_api_key_here

# آدرس پایه API رسلر (پیش‌فرض: https://api.reseller.world/v1.5)
RESELLER_BASE_URL=https://api.reseller.world/v1.5

# غیرفعال کردن بررسی SSL (فقط برای محیط توسعه!)
# DISABLE_SSL_VERIFY=true
